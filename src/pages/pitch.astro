---
import '@/styles/global.css';
import '@/styles/pitch.css';
import PitchApp from '@/components/pitch/PitchApp';
import { SLIDES } from '@/components/pitch/PitchApp';

const period = 'Mayo 2026';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#01205e" />
    <title>Dronena · Cierre comercial Mayo 2026</title>
    <meta
      name="description"
      content="Presentacion ejecutiva del cierre comercial de Dronena · Mayo 2026. Datos del Dashboard, insights y accionables."
    />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=geist:300,400,500,600,700|geist-mono:400,500,600&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#lamina-resumen">Saltar al contenido</a>

    <header class="pitch-header" aria-label="Presentacion del cierre">
      <div class="pitch-header__inner">
        <a class="pitch-brand" href="#lamina-resumen" aria-label="Ir al inicio de la presentacion">
          <span class="pitch-brand__mark" aria-hidden="true">DN</span>
          <span>
            <strong>Droguería La Nena</strong>
            <small>Cierre comercial · {period}</small>
          </span>
        </a>
        <nav class="pitch-nav" aria-label="Laminas de la presentacion">
          <button class="pitch-nav__toggle" type="button" aria-label="Abrir menú de láminas" aria-expanded="false" data-nav-toggle>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
          <div class="pitch-nav__list" data-nav-list>
            {
              SLIDES.map((s) => (
                <button data-pitch-nav={s.id} aria-current={s.id === 'resumen' ? 'true' : 'false'}>
                  <span class="pitch-nav__num">{s.num}</span>
                  {s.label}
                </button>
              ))
            }
          </div>
        </nav>
        <div class="pitch-actions">
          <span class="pitch-counter" aria-label="Periodo del cierre">{period}</span>
          <button class="pitch-btn" type="button" data-export-pdf>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 3v12" />
              <path d="M7 10l5 5 5-5" />
              <path d="M5 21h14" />
            </svg>
            Exportar PDF
          </button>
        </div>
      </div>
    </header>

    <main id="contenido" tabindex="-1">
      <PitchApp client:load />
    </main>
  </body>
</html>
